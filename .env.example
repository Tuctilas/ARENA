# Copie para .env (local) ou configure no Railway/Render (produção).

# Segredo para assinar os tokens JWT. Use uma string longa e aleatória.
# Gere uma com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque_por_um_segredo_forte_e_aleatorio

# Margem da casa (0 = justo · 0.45 = fase agressiva). Opcional.
HOUSE_EDGE=0.45

# Pasta de dados persistente (aponte para um volume em produção). Opcional.
# DATA_DIR=/data

# Porta (a plataforma normalmente define automaticamente). Opcional.
# PORT=3000

# ── DebitoPay (pagamentos reais) ──
# Sem estas variáveis, os depósitos funcionam em modo simulado (demo).
DEBITOPAY_BASE_URL=https://api.debitopay.com   # CONFIRMAR a URL base real (sandbox)
DEBITOPAY_KEY=sk_sandbox_xxx
DEBITOPAY_MERCHANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
DEBITOPAY_WALLET_CODE=00000
DEBITOPAY_WEBHOOK_SECRET=   # segredo para validar a assinatura do webhook (se houver)
# Header de autenticação (padrão: Authorization Bearer). Mude se a DebitoPay usar outro.
# DEBITOPAY_AUTH_HEADER=Authorization
# DEBITOPAY_AUTH_SCHEME=Bearer
# URL pública do site (para callback/return). Padrão já aponta pro Railway.
# PUBLIC_URL=https://web-production-ec637.up.railway.app
